---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  category: "finanse" | "marketing" | "logistyka";
  icon?: string; // ikona staje się opcjonalnym stringiem
  slug: string;
}

const { title, description, category, icon, slug } = Astro.props;

// Dynamicznie budujemy pełny adres URL (uwzględniając ewentualny BASE_URL)
const base = import.meta.env.BASE_URL;
const shareUrl = `${Astro.url.origin}${base}kalkulatory/${slug}`;
const encodedTitle = encodeURIComponent(title);
const encodedText = encodeURIComponent(`Sprawdź ten kalkulator: ${title}`);

// Szybkie mapowanie kategorii na nazwy ikon z Bootstrap Icons (bi:...)
const categoryIcons = {
  finanse: "bi:graph-up-arrow",
  marketing: "bi:bar-chart-line",
  logistyka: "bi:truck",
};

// Jeśli dostaliśmy konkretny string w propie 'icon', używamy go (np. 'bi:calculator').
// Jeśli nie, bierzemy ikonę kategorii, a w ostateczności domyślny kalkulator.
const iconName = icon || categoryIcons[category] || "bi:calculator";
---

<div
  class="group relative flex flex-col bg-white border border-gray-200 rounded-xl hover:border-gray-300 transition-all duration-300 h-full overflow-hidden"
>
  {
    /* Niewidoczny link pokrywający całą kartę (zapobiega konfliktowi zagnieżdżonych <a>) */
  }
  <a
    href={`/kalkulatory/${slug}`}
    class="absolute inset-0 z-10"
    aria-label={`Uruchom kalkulator: ${title}`}></a>

  {/* Główna zawartość karty */}
  <div class="p-6 flex flex-col grow">
    <div class="flex justify-between items-center mb-4">
      <div
        class="p-2.5 bg-gray-100 border border-gray-300 text-gray-600 rounded-lg"
      >
        <div
          class="p-2.5 bg-gray-100 border border-gray-300 text-gray-600 rounded-lg"
        >
          {
            /* Kontrola wielkości przez klasy Tailwind (np. w-6 h-6 to odpowiednik size={24}) */
          }
          <Icon name={iconName} class="w-6 h-6" />
        </div>
      </div>
      <span
        class="text-[10px] font-bold uppercase tracking-wider px-3 py-2 border border-gray-200 bg-gray-100 text-gray-500 rounded-full"
      >
        {category}
      </span>
    </div>

    <h3
      class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-emerald-700 transition-colors"
    >
      {title}
    </h3>

    <p class="text-sm text-gray-500 grow">
      {description}
    </p>
  </div>

  {/* Stopka karty */}
  <div
    class="bg-gray-100 border-t border-gray-200 px-6 py-3 flex items-center justify-between mt-auto"
  >
    <div class="flex items-center gap-3 relative z-20">
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Udostępnij na Facebooku"
        class="text-gray-400 hover:text-gray-600 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3.6l.4-4h-4V7a1 1 0 0 1 1-1h3z"
          ></path>
        </svg>
      </a>
      <a
        href={`https://www.linkedin.com/shareArticle?mini=true&url=${shareUrl}&title=${encodedTitle}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Udostępnij na LinkedIn"
        class="text-gray-400 hover:text-gray-600 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
      <a
        href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${encodedText}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Udostępnij na X/Twitter"
        class="text-gray-400 hover:text-gray-600 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
          <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
        </svg>
      </a>
    </div>
    <div
      class="flex items-center px-4 py-2 text-sm font-semibold text-white bg-gray-900 rounded-lg group-hover:bg-emerald-600 transition-colors"
    >
      Uruchom
      <div class="flex items-center px-4 py-2 text-sm font-semibold text-white bg-gray-900 rounded-lg group-hover:bg-emerald-600 transition-colors">
  Uruchom 
  <Icon name="bi:arrow-right" class="w-4 h-4 ml-1.5 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" />
</div>
    </div>
  </div>
</div>
