---
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-10">
      <div class="flex items-center">
       <a href={base} class="text-xl font-bold tracking-tight text-slate-900 transition-colors hover:text-slate-700">
  &lt;CStack.<span class="text-orange-500">eu</span>&gt;
</a>
      </div>
      <nav class="hidden md:flex items-center gap-4 [&>a]:text-gray-600 [&>a]:hover:text-gray-900 transition-colors">
        <a href={`${base}eksploruj`}>Kalkulatory</a>
        <a href={`${base}o-projekcie`}>O projekcie</a>
        <a href={`${base}kontakt`}>Kontakt</a>
      </nav>
    </div>

    <div class="flex items-center gap-4">
      <a href="https://linkedin.com/in/twoj-profil" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center p-2 rounded-lg text-slate-950 hover:text-[#0077B5] transition-colors" aria-label="LinkedIn" ><Icon name="bi:linkedin" class="w-5 h-5" />
      </a>

      <button id="mobile-menu-btn" class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-slate-950 hover:text-slate-700 transition-colors" aria-label="Otwórz menu" ><Icon name="bi:list" class="w-5 h-5" /> </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white backdrop-blur-md absolute top-full left-0 w-full shadow-lg" >
    <nav class="flex flex-col space-y-1 px-4 py-4 text-sm font-medium [&>a]:text-gray-600 [&>a]:hover:text-gray-900 transition-colors">
      <a href={`${base}eksploruj`} class="group flex items-center gap-2 rounded-lg p-2 transition-colors hover:bg-slate-100" > <span>Kalkulatory</span> </a>

      <a href={`${base}o-projekcie`} class="flex items-center rounded-lg p-2 transition-colors hover:bg-slate-100" > <span>O projekcie</span> </a>

      <a href={`${base}kontakt`} class="flex items-center rounded-lg p-2 transition-colors hover:bg-slate-100" > <span>Kontakt</span> </a>
    </nav>
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>