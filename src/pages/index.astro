---
import '../styles/global.css';
---

<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>CommerceStack</title>
  </head>

  <body class="bg-zinc-950 text-zinc-100 min-h-screen">
    <main class="flex min-h-screen items-center justify-center p-8">
      
      <div class="max-w-2xl rounded-3xl border border-zinc-800 bg-zinc-900/70 p-10 shadow-2xl backdrop-blur">
        
        <div class="mb-6 flex items-center gap-3">
          <div class="h-4 w-4 rounded-full bg-orange-500"></div>
          <div class="h-4 w-4 rounded-full bg-zinc-700"></div>
          <div class="h-4 w-4 rounded-full bg-zinc-700"></div>
        </div>

        <p class="mb-3 text-sm uppercase tracking-[0.3em] text-orange-400">
          CommerceStack
        </p>

        <h1 class="mb-6 text-5xl font-black leading-none tracking-tight md:text-7xl">
          Tailwind działa.
        </h1>

        <p class="mb-8 text-lg text-zinc-400">
          Astro + Tailwind + GitHub Pages zostały poprawnie wdrożone.
        </p>

        <div class="flex flex-wrap gap-4">
          <div class="rounded-2xl border border-zinc-700 px-5 py-3">
            Astro
          </div>

          <div class="rounded-2xl border border-zinc-700 px-5 py-3">
            TailwindCSS
          </div>

          <div class="rounded-2xl border border-orange-500 bg-orange-500/10 px-5 py-3 text-orange-300">
            GitHub Pages
          </div>
        </div>

      </div>

    </main>
  </body>
</html>
